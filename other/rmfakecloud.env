# rmfakecloud configuration — sourced by systemd via EnvironmentFile.
# All values are env-var assignments; no quoting unless the value contains
# whitespace. Lines beginning with '#' are ignored. See `rmfakecloud -h` or
# `internal/config/config.go` for the full env-var reference.

# ---- Required ---------------------------------------------------------------

# Random secret used to sign JWTs. If you change this, every issued token is
# invalidated (all sessions log out). Generate fresh with:
#     openssl rand -hex 48
JWT_SECRET_KEY=tbd

# Where rmfakecloud stores user data. Must be writable by the service user.
DATADIR=/var/rmfakecloud

# ---- Networking -------------------------------------------------------------

# Port for the HTTP API + admin UI. The systemd unit only allows ports
# >=1024 by default; lower ports require the install script to add
# AmbientCapabilities=CAP_NET_BIND_SERVICE.
PORT=3000

# URL the reMarkable tablet will use to reach this server. For device SW
# >= 3.15 this should be just the hostname (no port), with TLS terminated
# by a reverse proxy in front of rmfakecloud.
#STORAGE_URL=https://rm.example.com

# Send the auth cookie only over HTTPS. Set to 1 when running behind a TLS
# reverse proxy.
#RM_HTTPS_COOKIE=1

# Trust X-Forwarded-For / X-Real-IP headers. Only enable when behind a
# trusted reverse proxy that strips inbound copies.
#RM_TRUST_PROXY=1

# ---- Optional: registration -------------------------------------------------

# Allow public POST /register from localhost. First-user bootstrap does not
# need this — the very first POST to /login creates the admin (see
# internal/app/handlers.go's CreateFirstUser).
#OPEN_REGISTRATION=1

# ---- Optional: email (send-by-email feature) --------------------------------

#RM_SMTP_SERVER=smtp.example.com:587
#RM_SMTP_USERNAME=
#RM_SMTP_PASSWORD=
#RM_SMTP_FROM=rmfakecloud@example.com
#RM_SMTP_HELO=
#RM_SMTP_NOTLS=0
#RM_SMTP_STARTTLS=1
#RM_SMTP_INSECURE_TLS=0

# ---- Optional: handwriting recognition (MyScript) ---------------------------

#RMAPI_HWR_APPLICATIONKEY=
#RMAPI_HWR_HMAC=
#RMAPI_HWR_LANG_OVERRIDE=
#RMAPI_HWR_HOST=

# ---- Optional: MQTT (screenshare on newer firmware) -------------------------

#MQTT_PORT=8883
#ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]

# ---- Optional: OpenAPI / admin discovery ------------------------------------

# Mount /ui/api/openapi.json and /ui/api/docs/ for the Swagger UI.
# Default off because the admin API surface is sensitive.
#RM_ENABLE_OPENAPI=1

# ---- Optional: logging ------------------------------------------------------

#LOGLEVEL=info
#LOGFORMAT=text
# Leave RM_LOGFILE unset under systemd — stdout is captured by journald.
#RM_LOGFILE=

# ---- Optional: storage schema ----------------------------------------------

# sync15 hash-tree schema version. Default 3. Only change after reading the
# storage docs.
#HASH_SCHEMA_VERSION=3
